RewriteEngine On

# Redirect the old boot-camp URL to the new canonical route.
RewriteRule ^technopark/instructions/?$ /technopark/boot-camp [R=302,L]

# Prevent rewrite loops once the request is already inside /dist.
RewriteRule ^dist/ - [L]

# Always serve the built entry file instead of the Vite source index.html.
RewriteRule ^index\.html$ dist/index.html [L]

# Root domain should open the built app.
RewriteRule ^$ dist/index.html [L]

# If the requested path exists inside /dist, serve that built file or directory.
RewriteCond %{DOCUMENT_ROOT}/dist/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/dist/$1 -d
RewriteRule ^(.+)$ dist/$1 [L]

# SPA fallback for client-side routes such as /technopark and nested pages.
RewriteRule ^ dist/index.html [L]
