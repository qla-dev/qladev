RewriteEngine On

# Redirect legacy Technopark and deprecated instruction URLs to the new Techpark routes.
RewriteRule ^technopark/instructions/?$ /techpark/boot-camp [R=301,L]
RewriteRule ^technopark/boot-camp/?$ /techpark/boot-camp [R=301,L]
RewriteRule ^technopark/membership/?$ /techpark/membership [R=301,L]
RewriteRule ^technopark/sign-in/?$ /techpark/sign-in [R=301,L]
RewriteRule ^technopark/?$ /techpark [R=301,L]
RewriteRule ^techpark/instructions/?$ /techpark/boot-camp [R=301,L]

# Prevent rewrite loops once the request is already inside /dist.
RewriteRule ^dist/ - [L]

# Always serve the built entry file instead of the Vite source index.html.
RewriteRule ^index\.html$ dist/index.html [L]

# Root domain should open the built app.
RewriteRule ^$ dist/index.html [L]

# If the requested path exists inside /dist, serve that built file or directory.
RewriteCond %{DOCUMENT_ROOT}/dist/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/dist/$1 -d
RewriteRule ^(.+)$ dist/$1 [L]

# SPA fallback for client-side routes such as /techpark and nested pages.
RewriteRule ^ dist/index.html [L]
